{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 's=scripts/asb_resolve_root.sh; if [ -n \"${CLAUDE_PROJECT_DIR:-}\" ] && [ -f \"${CLAUDE_PROJECT_DIR%/}/$s\" ]; then R=\"$(cd \"$CLAUDE_PROJECT_DIR\" && pwd -P)\"; else f=; for c in \"$(git rev-parse --show-toplevel 2>/dev/null)\" ./*/ .; do [ -n \"$c\" ] && [ -f \"${c%/}/$s\" ] && { f=\"${c%/}/$s\"; break; }; done; R=\"$([ -n \"$f\" ] && bash \"$f\")\"; fi; [ -n \"$R\" ] && exec bash \"$R/.claude/hooks/session-start.sh\"'",
            "timeout": 120
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|Bash|mcp__.*__execute_sql|mcp__.*__apply_migration",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/preflight-gate.sh\"",
            "timeout": 15,
            "statusMessage": "STOP GATE governanca (pre-flight)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/graphify-auto.sh\"",
            "timeout": 20
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/pre-compact.sh\"",
            "timeout": 20
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/session-end.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
