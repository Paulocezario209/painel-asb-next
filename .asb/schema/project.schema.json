{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "asb-project-state",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "project", "mission", "authority_source", "autonomy_defaults", "updated_at"],
  "properties": {
    "schema_version": { "type": "integer", "enum": [1] },
    "project": { "type": "string", "minLength": 3, "maxLength": 60 },
    "mission": { "type": "string", "minLength": 10, "maxLength": 280 },
    "origin": { "type": "string", "maxLength": 500 },
    "authority_source": { "type": "string", "minLength": 10, "maxLength": 160 },
    "global_prohibited_scope": {
      "type": "array", "maxItems": 30,
      "items": { "type": "string", "minLength": 3, "maxLength": 140 }
    },
    "autonomy_defaults": {
      "type": "object", "additionalProperties": false,
      "required": ["default_mode"],
      "properties": {
        "default_mode": { "enum": ["autonomous_within_scope", "execute_and_report", "requires_genesis", "requires_paulo", "blocked"] }
      }
    },
    "debt_log_ref": { "type": "string", "maxLength": 80 },
    "updated_at": { "type": "string", "format": "date-time", "minLength": 20, "maxLength": 40 }
  }
}
